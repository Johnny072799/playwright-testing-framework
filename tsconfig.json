{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": [
    "tests/cucumber/**/*.ts",
    "cucumber.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
