{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": [
    "playwright.config.ts",
    "fixtures/**/*.ts",
    "tests/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
